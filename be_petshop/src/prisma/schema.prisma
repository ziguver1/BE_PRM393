datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  UserId       Int            @id @default(autoincrement())
  FullName     String
  Email        String         @unique
  PasswordHash String
  Phone        String?
  Avatar       String?
  Role         String         @default("CUSTOMER") // CUSTOMER, ADMIN
  fcmToken     String?        // Token để gửi thông báo qua Firebase Cloud Messaging
  gender       String?
  birthday     DateTime?
  bio          String?
  CreatedAt    DateTime       @default(now())
  UpdatedAt    DateTime       @updatedAt
  CartItems    CartItem[]
  Orders       Order[]
  Notifications Notification[]
  Conversation  Conversation?
  Wishlists    Wishlist[]
}

model Category {
  CategoryId  Int       @id @default(autoincrement())
  Name        String
  Description String?
  ImageUrl    String?
  Products    Product[]
}

model Product {
  ProductId    Int           @id @default(autoincrement())
  CategoryId   Int
  Name         String
  Description  String?
  Price        Float
  Stock        Int
  ImageUrl     String?
  Variants     Json?         // e.g. [{"name": "1 Kg", "price": 85000, "stock": 50}]
  VariantLabel String?       // e.g. "Khối lượng", "Kích cỡ", "Dung tích"
  Unit         String        @default("cái") // e.g. "túi", "lon", "cái", "chai", "hộp"
  CreatedAt    DateTime      @default(now())
  UpdatedAt    DateTime      @updatedAt
  Category     Category      @relation(fields: [CategoryId], references: [CategoryId], onDelete: Cascade)
  CartItems    CartItem[]
  OrderDetails OrderDetail[]
  ProductVariants ProductVariant[]
  Images       ProductImage[]
  Attributes   ProductAttribute[]
  ProductFilters ProductFilter[]
  Wishlists    Wishlist[]
}

model CartItem {
  CartItemId      Int     @id @default(autoincrement())
  UserId          Int
  ProductId       Int
  ProductVariantId Int?
  SelectedVariant String  @default("")
  Quantity        Int
  User            User    @relation(fields: [UserId], references: [UserId], onDelete: Cascade)
  Product         Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
  ProductVariant  ProductVariant? @relation(fields: [ProductVariantId], references: [ProductVariantId], onDelete: SetNull)

  @@unique([UserId, ProductId, SelectedVariant])
  @@index([ProductVariantId])
}

model Order {
  OrderId         Int           @id @default(autoincrement())
  OrderCode       Int?          @unique // Bắt buộc cho PayOS (Để optional ? để không lỗi data cũ)
  UserId          Int
  TotalAmount     Float
  ShippingAddress String
  Status          String        @default("PENDING") // PENDING, PROCESSING, SHIPPING, DELIVERED, PAID, RECEIVED, CANCELLED
  UserLat         Float?        // Tọa độ latitude của người dùng
  UserLng         Float?        // Tọa độ longitude của người dùng
  RoutePoints     Json?         // Mảng lộ trình từ OSRM [{lat, lng}, ...]
  ShippingStartedAt DateTime?   // Thời điểm bắt đầu giao hàng
  CreatedAt       DateTime      @default(now())
  User            User          @relation(fields: [UserId], references: [UserId], onDelete: Cascade)
  OrderDetails    OrderDetail[]
}

model OrderDetail {
  OrderDetailId   Int     @id @default(autoincrement())
  OrderId         Int
  ProductId       Int
  ProductVariantId Int?
  SelectedVariant String  @default("")
  ProductNameSnapshot String?
  ProductImageSnapshot String?
  VariantSkuSnapshot String?
  VariantNameSnapshot String?
  VariantImageSnapshot String?
  VariantOptionsSnapshot String?
  Quantity        Int
  UnitPrice       Float
  Order           Order   @relation(fields: [OrderId], references: [OrderId], onDelete: Cascade)
  Product         Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
  ProductVariant  ProductVariant? @relation(fields: [ProductVariantId], references: [ProductVariantId], onDelete: SetNull)

  @@index([ProductVariantId])
}

model Notification {
  NotificationId Int      @id @default(autoincrement())
  UserId         Int
  Title          String
  Content        String
  IsRead         Boolean  @default(false)
  CreatedAt      DateTime @default(now())
  User           User     @relation(fields: [UserId], references: [UserId], onDelete: Cascade)
}

model Conversation {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastMessage    String?
  lastMessageAt  DateTime?
  unreadCustomer Int       @default(0)
  unreadAdmin    Int       @default(0)

  User     User      @relation(fields: [userId], references: [UserId], onDelete: Cascade)
  Messages Message[]
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderType     String       // "Customer" | "Admin"
  senderId       Int
  message        String
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  status         String       @default("SENT") // "SENT", "DELIVERED", "READ"
  messageType    String       @default("TEXT") // TEXT, IMAGE, SYSTEM, FILE
  sentAt         DateTime     @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?

  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  ProductVariantId Int    @id @default(autoincrement())
  ProductId        Int
  Name             String? // e.g. "1 Kg", "2 Kg", "Pack of 3"
  Price            Float
  Stock            Int
  Unit             String? // e.g. "kg", "lon", "cái"
  Attributes       Json?   // any extra attributes
  Product          Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
  CartItems        CartItem[]
  OrderDetails     OrderDetail[]
}

model FilterGroup {
  FilterGroupId Int            @id @default(autoincrement())
  Name          String         // VD: "Thương hiệu", "Độ tuổi", "Hương vị"
  Description   String?
  Options       FilterOption[]
}

model FilterOption {
  FilterOptionId Int            @id @default(autoincrement())
  FilterGroupId  Int
  Value          String         // VD: "Royal Canin", "Chó con (Puppy)", "Vị cá hồi"
  Group          FilterGroup    @relation(fields: [FilterGroupId], references: [FilterGroupId], onDelete: Cascade)
  ProductFilters ProductFilter[]
}

model ProductFilter {
  ProductId      Int
  FilterOptionId Int
  
  Product        Product        @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
  FilterOption   FilterOption   @relation(fields: [FilterOptionId], references: [FilterOptionId], onDelete: Cascade)

  // Khóa chính kép: Đảm bảo 1 sản phẩm không bị gán trùng 1 thẻ filter
  @@id([ProductId, FilterOptionId]) 
}

// ==========================================
// CÁC BẢNG BỔ TRỢ KHÁC (Đã khai báo ở Product nhưng chưa có model)
// ==========================================

model ProductImage {
  ProductImageId Int     @id @default(autoincrement())
  ProductId      Int
  ImageUrl       String
  IsPrimary      Boolean @default(false) // Xác định ảnh bìa chính
  Product        Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
}

model ProductAttribute {
  ProductAttributeId Int     @id @default(autoincrement())
  ProductId          Int
  Name               String  // VD: "Thành phần", "Hướng dẫn sử dụng"
  Value              String  @db.Text
  Product            Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)
}

model NotificationLog {
  NotificationLogId Int      @id @default(autoincrement())
  OrderId           Int
  UserId            Int
  Type              String   // e.g. "ORDER_SHIPPING_STARTED", "ORDER_DELIVERED"
  SentAt            DateTime @default(now())
  Status            String   // "SUCCESS", "FAILED"
  FailureReason     String?

  @@unique([OrderId, Type]) // Idempotency constraint to prevent duplicates
}

model Wishlist {
  WishlistId Int      @id @default(autoincrement())
  UserId     Int
  ProductId  Int
  CreatedAt  DateTime @default(now())

  User    User    @relation(fields: [UserId], references: [UserId], onDelete: Cascade)
  Product Product @relation(fields: [ProductId], references: [ProductId], onDelete: Cascade)

  @@unique([UserId, ProductId])
}